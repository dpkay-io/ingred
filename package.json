{
  "name": "ingred",
  "version": "0.1.0",
  "description": "Compile personalized AI coding instructions into native agent config files",
  "type": "module",
  "bin": {
    "ingred": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test tests/unit/frontmatter.test.ts tests/unit/detector.test.ts tests/unit/matcher.test.ts tests/unit/compiler.test.ts tests/unit/mix-interactive.test.ts tests/unit/privacy.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "ai",
    "coding-instructions",
    "claude",
    "cursor",
    "copilot",
    "agents",
    "developer-tools",
    "cli"
  ],
  "license": "MIT"
}
